    "@prisma-next-idb/runtime-idb": "workspace:*"
  },
  "devDependencies": {
    "@prisma-next-idb/family-idb": "workspace:*",
    "fake-indexeddb": "^6.2.5",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^3.2.0"
