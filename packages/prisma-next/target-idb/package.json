    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@prisma-next/contract": "^0.14.0",
    "@prisma-next/framework-components": "^0.14.0",
    "@prisma-next/migration-tools": "^0.14.0",
    "pathe": "^2.0.3"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "fake-indexeddb": "^6.2.5",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
