{
  "name": "@prisma-next-idb/adapter-idb",
  "version": "0.0.1",
  "description": "Prisma Next IDB family — adapter (lowers query AST to opaque IDB plan body)",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./control": "./dist/control.mjs",
    "./runtime": "./dist/runtime.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@prisma-next-idb/driver-idb": "workspace:*",
    "@prisma-next-idb/target-idb": "workspace:*",
    "@prisma-next/framework-components": "^0.14.0"
  },
  "devDependencies": {
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
