{
  "name": "@prisma-idb/idb-client-generator",
  "description": "Prisma generator for a type-safe IndexedDB client with optional sync",
  "version": "0.0.0-semantically-released",
  "main": "dist/generator.js",
  "license": "MIT",
  "bin": {
    "idb-client-generator": "bin.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node dist/bin.js",
    "dev": "tsc --watch",
    "build": "tsc",
    "prepack": "pnpm build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "release": "release-it",
    "prepare": "tsc"
  },
  "dependencies": {
    "@prisma/generator-helper": "^7.7.0",
    "code-block-writer": "^13.0.3",
    "prettier": "^3.8.3"
  },
  "devDependencies": {
    "@prisma/internals": "^7.7.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/node": "^24.12.2",
    "release-it": "^19.2.4",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@paralleldrive/cuid2": "^3.0.0",
    "@prisma/client": "^6.0.0 || ^7.0.0",
    "idb": "^8.0.0",
    "prisma": "^6.0.0 || ^7.0.0",
    "uuid": ">=9.0.0"
  },
  "peerDependenciesMeta": {
    "uuid": {
      "optional": true
    },
    "@paralleldrive/cuid2": {
      "optional": true
    }
  },
  "homepage": "https://prisma-idb.dev/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prisma-idb/idb-client-generator.git"
  },
  "author": "Yash Kolekar (https://whyash5114.com/)",
  "keywords": ["prisma", "generator", "indexeddb", "offline-first", "sync"],
  "bugs": {
    "url": "https://github.com/prisma-idb/idb-client-generator/issues"
  }
}
