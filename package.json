{
  "name": "@prisma-idb/monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --no-cache",
    "check": "pnpm check:prisma-next-descriptors && turbo run check",
    "check:prisma-next-descriptors": "tsx scripts/check-prisma-next-descriptor-consistency.ts",
    "lint": "turbo run lint",
    "format": "turbo run format --no-cache",
    "test": "turbo run test",
    "test:generator-client": "turbo run test --filter=@prisma-idb/usage",
    "test:generator-sync": "turbo run test --filter=@prisma-idb/kanban-example",
    "test:generator-schema": "turbo run test --filter=@prisma-idb/schema-gen-tests",
    "test:prisma-next": "turbo run test --filter=@prisma-next-idb/adapter-idb --filter=@prisma-next-idb/client-idb --filter=@prisma-next-idb/driver-idb --filter=@prisma-next-idb/family-idb --filter=@prisma-next-idb/runtime-idb --filter=@prisma-next-idb/target-idb --filter=@prisma-next-idb/cli-tests",
    "test:prisma-next-e2e": "turbo run test --filter=@prisma-next-idb/usage",
    "test:prisma-next-kanban-e2e": "turbo run test --filter=@prisma-next-idb/kanban-example",
    "test:benchmark": "turbo run test --filter=@prisma-idb/benchmark",
    "benchmark:local": "bash scripts/benchmark-local.sh",
    "test:watch": "turbo run test:watch --no-cache",
    "generate": "turbo run generate",
    "clean": "turbo clean && rm -rf node_modules",
    "preview": "turbo run preview",
    "run:ci": "pnpm format && pnpm generate && pnpm lint && pnpm check && pnpm build",
    "prepare": "husky",
    "changeset": "changeset",
    "version:prisma-next": "changeset version",
    "release:prisma-next": "pnpm build --filter=@prisma-next-idb/* && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.10.9",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.19.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4.1.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.22.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "lint-staged": {
    "*.{js,ts,svelte,tsx,jsx,mjs}": ["prettier --write", "eslint --fix"],
    "*.{json,md,mdx,css,html,yaml,yml}": ["prettier --write"]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prisma-idb/idb-client-generator.git"
  }
}
