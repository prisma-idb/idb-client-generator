generator client {
  provider = "prisma-client"
  output   = "../../../generated/prisma-migrations-test"
}

generator prismaIDB {
  provider                      = "idb-client-generator"
  output                        = "../../../generated/prisma-idb-migrations-test"
  dropDbOnSchemaVersionMismatch = true
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String @id @default(uuid())
  name  String
  email String @unique
  posts Post[]
}

model Post {
  id       String @id @default(uuid())
  title    String
  author   User   @relation(fields: [authorId], references: [id])
  authorId String
}
